# --- Database (Neon Postgres) ---
# Pooled connection string (used at runtime)
DATABASE_URL="postgresql://<user>:<password>@<endpoint>-pooler.<region>.aws.neon.tech/<db>?sslmode=verify-full&channel_binding=require"
# Direct (non-pooled) endpoint — used by Prisma CLI for migrations
DIRECT_DATABASE_URL="postgresql://<user>:<password>@<endpoint>.<region>.aws.neon.tech/<db>?sslmode=verify-full&channel_binding=require"

# --- Redis (optional; in-memory fallback is used when absent) ---
REDIS_URL="redis://localhost:6380"

# --- Free AI providers ---
# Groq: https://console.groq.com/keys
GROQ_API_KEY=""
# OpenRouter: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=""
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Cloudflare Workers AI — the only working free image-generation route.
# Account ID: Cloudflare dashboard → Workers & Pages → Account ID (right sidebar).
# API token: https://dash.cloudflare.com/profile/api-tokens → Create Token →
#   "Workers AI (Read)" template (permission: Account → Workers AI → Read).
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

# --- Abuse protection (public app, no auth) ---
# Max chat requests per IP per minute
RATE_LIMIT_PER_MINUTE="10"
# Max chat requests per IP per day
RATE_LIMIT_PER_DAY="200"
# Global daily request kill switch (all users combined)
GLOBAL_DAILY_REQUEST_CAP="5000"
